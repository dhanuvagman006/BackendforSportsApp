# --- core -------------------------------------------------------------
ENVIRONMENT=development
BASE_URL=http://localhost:8000
SHARE_BASE_URL=https://sportyqo.app
DATABASE_URL=postgresql+asyncpg://sportyqo:sportyqo@localhost:5432/sportyqo
# Flutter Web origin(s), comma separated; * for local dev only
CORS_ORIGINS=*

# --- auth --------------------------------------------------------------
JWT_SECRET=change-me-in-production
ADMIN_API_KEY=change-me-admin-key

# --- providers (console/local defaults need no credentials) -------------
SMS_PROVIDER=console          # console | msg91 | twilio
EMAIL_PROVIDER=console        # console | smtp
PUSH_PROVIDER=console         # console | fcm
STORAGE_PROVIDER=local        # local | s3
STORAGE_DIR=./storage

# MSG91_AUTH_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=no-reply@sportyqo.com
# FCM_SERVICE_ACCOUNT_JSON=
# S3_BUCKET=
# S3_REGION=ap-south-1
# CDN_BASE_URL=

# --- Qo Score weights (tunable without code changes) ---------------------
# POINTS_PER_RUN=0.5
# POINTS_PER_WICKET=20
# POINTS_PER_CATCH=10
# POINTS_MOM_BONUS=25
# POINTS_WIN_BONUS=15
# POINTS_PARTICIPATION=5
